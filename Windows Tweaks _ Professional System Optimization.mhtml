function copyText(type){
    let text = "";

    if(type === "clean") text = "cleanmgr /sagerun:1";
    if(type === "net") text = "ipconfig /flushdns";
    if(type === "fps") text = "bcdedit /set useplatformtick yes";

    navigator.clipboard.writeText(text);
    alert(lang === "ar" ? "تم النسخ ✅" : "Copied ✅");
}
